{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaas.to/spec/0.1/attestation.schema.json",
  "title": "attestation.sig \u2014 spec 0.1",
  "type": "object",
  "$defs": {},
  "properties": {
    "gaas_spec": {
      "const": "0.1"
    },
    "org": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,64}$"
    },
    "manifest": {
      "type": "object",
      "patternProperties": {
        "^(auth|policy|audit|escalation)\\.md$": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "algo": {
      "const": "ES256"
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "key_id": {
            "type": "string",
            "minLength": 1
          },
          "signer": {
            "enum": [
              "org",
              "runtime"
            ]
          },
          "sig": {
            "type": "string",
            "minLength": 1
          },
          "signed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "key_id",
          "signer",
          "sig",
          "signed_at"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "gaas_spec",
    "org",
    "manifest",
    "manifest_hash",
    "algo",
    "signatures"
  ],
  "additionalProperties": false
}
